{
  "name": "@opencrush/autonomous",
  "version": "0.1.0",
  "description": "Autonomous behavior: scheduler, music awareness, drama tracking, proactive messaging",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs",
    "dev": "tsup src/index.ts --format esm,cjs --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opencrush/core": "workspace:*",
    "@opencrush/media": "workspace:^",
    "node-cron": "^3.0.3",
    "playwright": "^1.49.0"
  },
  "optionalDependencies": {
    "goat-x": "^1.4.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node-cron": "^3.0.11",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
