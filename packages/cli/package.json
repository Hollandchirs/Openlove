{
  "name": "@openlove/cli",
  "version": "0.1.0",
  "description": "CLI: setup wizard, character creator, start command",
  "bin": {
    "openlove": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "setup": "node dist/index.js setup",
    "start": "node dist/index.js start",
    "wakeup": "node dist/index.js wakeup",
    "create": "node dist/index.js create",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@openlove/core": "workspace:*",
    "@openlove/bridge-discord": "workspace:*",
    "@openlove/bridge-telegram": "workspace:*",
    "@openlove/media": "workspace:*",
    "@openlove/autonomous": "workspace:*",
    "@anthropic-ai/sdk": "^0.32.0",
    "dotenv": "^16.4.7",
    "inquirer": "^12.3.0",
    "chalk": "^5.3.0",
    "figlet": "^1.8.0",
    "ora": "^8.1.1",
    "boxen": "^8.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/inquirer": "^9.0.7",
    "typescript": "^5.7.0",
    "tsup": "^8.3.0"
  }
}
