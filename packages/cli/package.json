{
  "name": "opencrush",
  "version": "0.3.23",
  "description": "Your AI companion lives on your device. She watches dramas, listens to music, and thinks of you.",
  "bin": {
    "opencrush": "dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "setup": "node dist/index.js setup",
    "start": "node dist/index.js start",
    "wakeup": "node dist/index.js wakeup",
    "create": "node dist/index.js create",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "companion",
    "girlfriend",
    "chatbot",
    "discord",
    "telegram",
    "whatsapp",
    "open-source",
    "self-hosted",
    "autonomous"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hollandchirs/Opencrush.git"
  },
  "homepage": "https://github.com/Hollandchirs/Opencrush",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "sharp": "^0.33.0"
  },
  "optionalDependencies": {
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@opencrush/autonomous": "workspace:*",
    "@opencrush/bridge-discord": "workspace:*",
    "@opencrush/bridge-telegram": "workspace:*",
    "@opencrush/core": "workspace:*",
    "@opencrush/media": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/figlet": "^1.7.0",
    "@types/inquirer": "^9.0.7",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.7",
    "figlet": "^1.8.0",
    "gray-matter": "^4.0.3",
    "inquirer": "^12.3.0",
    "ora": "^8.1.1",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "zod": "^3.24.0"
  }
}
