{
  "name": "@opencrush/bridge-whatsapp",
  "version": "0.1.0",
  "description": "WhatsApp bridge: text, voice messages, media via Baileys",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs",
    "dev": "tsup src/index.ts --format esm,cjs --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opencrush/core": "workspace:*",
    "@opencrush/media": "workspace:*",
    "@whiskeysockets/baileys": "^6.7.16",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/qrcode-terminal": "^0.12.0",
    "typescript": "^5.7.0",
    "tsup": "^8.3.0"
  }
}
