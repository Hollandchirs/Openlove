{
  "name": "@opencrush/bridge-discord",
  "version": "0.1.0",
  "description": "Discord bridge: text, voice calls, media",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs",
    "dev": "tsup src/index.ts --format esm,cjs --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opencrush/core": "workspace:*",
    "@opencrush/media": "workspace:*",
    "@opencrush/autonomous": "workspace:*",
    "discord.js": "^14.16.0",
    "@discordjs/voice": "^0.17.0",
    "@discordjs/opus": "^0.9.0",
    "prism-media": "^1.3.5",
    "sodium-native": "^4.3.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.3.0"
  }
}
