# =============================================================
# Openlove Configuration
# Copy this file to .env and fill in your values
# Get help: https://github.com/Hollandchirs/Openlove/wiki/api-keys
# =============================================================

# ── LLM — pick ONE provider ─────────────────────────────────
# Which LLM to use (set to your chosen provider below)
# Options: anthropic | openai | deepseek | qwen | kimi | zhipu | minimax | ollama
LLM_PROVIDER=anthropic

# Override the default model (optional — leave blank to use provider default)
LLM_MODEL=

# ── International providers ──────────────────────────────────
# Anthropic Claude — best for roleplay (needs VPN in mainland China)
# Get from: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=

# OpenAI GPT — reliable, widely supported (needs VPN in mainland China)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Chinese providers (no VPN needed from mainland China) ────
# DeepSeek — powerful reasoning, very affordable
# Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# 通义千问 Qwen — Alibaba, strong Chinese + English
# Get from: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=

# Kimi / Moonshot — long context, natural conversation
# Get from: https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=

# 智谱 GLM — Tsinghua-backed, free tier available
# Get from: https://open.bigmodel.cn/usercenter/proj-mgmt/apikeys
ZHIPU_API_KEY=

# MiniMax — roleplay-optimized, character voice support
# Get from: https://platform.minimaxi.com/user-center/basic-information/interface-key
MINIMAX_API_KEY=

# ── Local inference (completely free) ───────────────────────
# Ollama — runs on your own machine, no API key needed
# Install: https://ollama.ai  then run: ollama pull qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── Active Character ────────────────────────────────────────
# The folder name inside /characters/
CHARACTER_NAME=mia

# ── Messaging Platforms (enable at least one) ───────────────

# Discord
# Get from: https://discord.com/developers/applications → Bot → Token
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
# Your Discord user ID (right-click your name → Copy User ID)
DISCORD_OWNER_ID=

# Telegram
# Get from: https://t.me/botfather → /newbot
TELEGRAM_BOT_TOKEN=
# Your Telegram user ID (@userinfobot will tell you)
TELEGRAM_OWNER_ID=

# WhatsApp (no token needed — uses QR code pairing)
WHATSAPP_ENABLED=false

# ── Image Generation ────────────────────────────────────────
# Get from: https://fal.ai (free credits available)
FAL_KEY=

# Image model (flux-realism for photorealistic selfies, flux/dev for artistic)
IMAGE_MODEL=fal-ai/flux-realism

# ── Voice ───────────────────────────────────────────────────
# Get from: https://elevenlabs.io (10k chars/month free)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# OR use free local TTS (no key needed)
TTS_PROVIDER=elevenlabs

# ── Voice Conversation ────────────────────────────────────
# Enable real-time voice conversation in Discord voice channels
# Requires OPENAI_API_KEY for Whisper speech-to-text
VOICE_CONVERSATION_ENABLED=true

# ── Autonomous Behavior ─────────────────────────────────────
# Spotify (for music awareness)
# Get from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# TMDB (for drama/movie awareness)
# Get from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ── Behavior Timing ─────────────────────────────────────────
# How often she reaches out to you proactively (minutes)
PROACTIVE_MESSAGE_MIN_INTERVAL=60
PROACTIVE_MESSAGE_MAX_INTERVAL=240

# Quiet hours (she won't message during these hours)
QUIET_HOURS_START=23
QUIET_HOURS_END=8

# ── Browser Automation ────────────────────────────────────
# Enable real browser windows (Playwright) for simulated activities
# Install browser: npx playwright install chromium
BROWSER_AUTOMATION_ENABLED=true
